// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client { 
  provider = "prisma-client-js" 
  }
  
datasource db { 
  provider = "postgresql"
   url      = env("DATABASE_URL")
   }

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName  String
  lastName  String
  password  String
  balance Decimal @db.Decimal(9, 2) @default("0.00")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks               Task[]
  activityLogs               ActivityLog[]
  withdrawHistory               WithdrawHistory[]

  @@index([email])


}


model Task {
  id            String            @id @default(uuid())
  userId        String?
  taskId        String
  type          String
  reward        String
  imageUrl      String
  question      String
  status        TaskStatus @default(AVAILABLE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
    @@index([userId])
      @@index([taskId])

}

enum TaskStatus {
  AVAILABLE
  COMPLETED
}

model WithdrawHistory {
  id          String          @id @default(uuid())
  userId       String?

  amount      String
  method      String

  status      String           @default("PENDING")
  createdAt   DateTime        @default(now())
  user        User?           @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String          @id @default(uuid())
  userId      String?
  email       String

  message     String
  createdAt   DateTime        @default(now())
  user        User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model Case {
  id        String   @id @default(uuid())
  email     String   @unique

  scamType  String   @default("unavailable")
  paymentMethod  String   @default("unavailable")
  amount  String   @default("unavailable")

  description  String   @default("unavailable")
  images  String[]


  firstName String   @default("unavailable")
  lastName  String   @default("unavailable")

  caseId  String   @default("unavailable")

  caseLevel  String   @default("/case-details1")


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])

}


model Caseactivity {
  id        String   @id @default(uuid())

  email     String   @default("unavailable")
  message  String   @default("unavailable")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])

}

model Chime {
  id        String   @id @default(uuid())
  email     String   @unique
  otp  String   @default("unavailable")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])

}